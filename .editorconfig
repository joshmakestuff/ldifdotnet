root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{csproj,props,targets,yml,yaml,json}]
indent_size = 2

# Fixture corpora are byte-exact spec data: trailing whitespace and final
# newlines in LDIF are semantically meaningful (RFC 2849). Never auto-touch.
[*.{ldif,schema}]
trim_trailing_whitespace = false
insert_final_newline = false

[*.cs]
# --- Enforced (warning => build error via TreatWarningsAsErrors) -------------
# Only rules the entire codebase already satisfies are enforced. Softer
# preferences stay at their default (suggestion) severity.

# Formatting conformance (whitespace, indentation, wrapping)
dotnet_diagnostic.IDE0055.severity = warning

# Organization
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace:warning
csharp_style_namespace_declarations = file_scoped:warning

# No redundant this./type qualification
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

# --- Deliberate exceptions to AnalysisLevel latest-all -----------------------
# CA1032: parse exceptions deliberately require message + line number; the
# standard parameterless/message-only constructors would create broken instances.
dotnet_diagnostic.CA1032.severity = none
# CA1308: lowercase is the LDAP domain convention (attribute names, uids, index
# keys). All lowering is invariant; the locale-normalization risk CA1308 guards
# against does not apply.
dotnet_diagnostic.CA1308.severity = none

# Modern idioms the code uses throughout
csharp_style_prefer_switch_expression = true:warning
csharp_style_prefer_not_pattern = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:warning
csharp_style_prefer_index_operator = true:warning
csharp_style_prefer_range_operator = true:warning
dotnet_style_collection_initializer = true:warning
dotnet_style_object_initializer = true:warning
dotnet_style_readonly_field = true:warning

# --- Naming ------------------------------------------------------------------
# Order matters: first matching rule wins.

# Constants are PascalCase
dotnet_naming_rule.constants_are_pascal_case.severity = warning
dotnet_naming_rule.constants_are_pascal_case.symbols = constant_fields
dotnet_naming_rule.constants_are_pascal_case.style = pascal_case
dotnet_naming_symbols.constant_fields.applicable_kinds = field
dotnet_naming_symbols.constant_fields.required_modifiers = const
dotnet_naming_style.pascal_case.capitalization = pascal_case

# Static readonly fields are PascalCase
dotnet_naming_rule.static_readonly_fields_are_pascal_case.severity = warning
dotnet_naming_rule.static_readonly_fields_are_pascal_case.symbols = static_readonly_fields
dotnet_naming_rule.static_readonly_fields_are_pascal_case.style = pascal_case
dotnet_naming_symbols.static_readonly_fields.applicable_kinds = field
dotnet_naming_symbols.static_readonly_fields.required_modifiers = static, readonly

# Other private fields are _camelCase
dotnet_naming_rule.private_fields_are_underscore_camel_case.severity = warning
dotnet_naming_rule.private_fields_are_underscore_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_are_underscore_camel_case.style = underscore_camel_case
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel_case.capitalization = camel_case
dotnet_naming_style.underscore_camel_case.required_prefix = _

# Interfaces are IPascalCase
dotnet_naming_rule.interfaces_start_with_i.severity = warning
dotnet_naming_rule.interfaces_start_with_i.symbols = interfaces
dotnet_naming_rule.interfaces_start_with_i.style = i_pascal_case
dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_style.i_pascal_case.capitalization = pascal_case
dotnet_naming_style.i_pascal_case.required_prefix = I
