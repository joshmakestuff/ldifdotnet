<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="local-packages" value="../../packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <!-- The LdifDotNet packages must come from the freshly packed local feed,
         never from nuget.org (which could host an unrelated same-named package). -->
    <packageSource key="local-packages">
      <package pattern="LdifDotNet*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
